@prefix hw1:    <http://taica.course/hw1/ontology#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <https://schema.org/> .

# ---- classes ----
hw1:Batch     a rdfs:Class .
hw1:Frame     a rdfs:Class .
hw1:RGBImage   rdfs:subClassOf schema:ImageObject .
hw1:DepthImage rdfs:subClassOf schema:ImageObject .
hw1:QualityFactor a rdfs:Class .

# ---- object properties ----
hw1:hasFrame      a rdf:Property ; rdfs:domain hw1:Batch ; rdfs:range hw1:Frame .
hw1:hasRGBImage   a rdf:Property ; rdfs:domain hw1:Frame ; rdfs:range hw1:RGBImage .
hw1:hasDepthImage a rdf:Property ; rdfs:domain hw1:Frame ; rdfs:range hw1:DepthImage .

# ---- datatype properties ----
hw1:batchName          a rdf:Property ; rdfs:domain hw1:Batch ; rdfs:range xsd:string .
hw1:batchPath          a rdf:Property ; rdfs:domain hw1:Batch ; rdfs:range xsd:string .
hw1:floor              a rdf:Property ; rdfs:domain hw1:Batch ; rdfs:range xsd:integer .
hw1:frameIndex         a rdf:Property ; rdfs:domain hw1:Frame ; rdfs:range xsd:integer .
hw1:avgLuma            a rdf:Property ; rdfs:domain hw1:RGBImage ; rdfs:range xsd:double .
hw1:validDepthFraction a rdf:Property ; rdfs:domain hw1:DepthImage ; rdfs:range xsd:double .

# ---- data-quality qualification factors ----
# Bands intentionally have no pre-defined min/max here; supply them at query time.
hw1:GoodBrightnessRange a hw1:QualityFactor ;
    rdfs:comment "avg_luma_rec601 band (see definitions.md)" .

hw1:ValidDepthRatio a hw1:QualityFactor ;
    rdfs:comment "valid_depth_fraction minimum (see definitions.md)" .
